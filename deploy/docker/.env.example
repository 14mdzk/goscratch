# =============================================================================
# goscratch Production Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values before deploying.

# Application
APP_ENV=production
APP_PORT=3000
APP_NAME=goscratch

# PostgreSQL
POSTGRES_USER=goscratch
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
POSTGRES_DB=goscratch
DATABASE_URL=postgres://goscratch:CHANGE_ME_strong_password_here@postgres:5432/goscratch?sslmode=disable

# Redis
REDIS_HOST=redis:6379
REDIS_PASSWORD=CHANGE_ME_redis_password_here

# RabbitMQ
RABBITMQ_USER=goscratch
RABBITMQ_PASSWORD=CHANGE_ME_rabbitmq_password_here
RABBITMQ_URL=amqp://goscratch:CHANGE_ME_rabbitmq_password_here@rabbitmq:5672/

# JWT
JWT_SECRET=CHANGE_ME_generate_a_64_char_random_string
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h

# AWS S3 (optional)
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_BUCKET=

# Observability (optional)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4317
