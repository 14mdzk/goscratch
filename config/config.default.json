{
  "app": {
    "name": "goscratch",
    "env": "development"
  },
  "server": {
    "host": "0.0.0.0",
    "port": 8080,
    "read_timeout": 10,
    "write_timeout": 10,
    "idle_timeout": 120
  },
  "database": {
    "host": "localhost",
    "port": 5432,
    "user": "postgres",
    "password": "postgres",
    "name": "goscratch",
    "ssl_mode": "require",
    "max_open_conns": 25,
    "max_idle_conns": 5,
    "conn_max_lifetime": 300
  },
  "jwt": {
    "secret": "your-super-secret-key-change-in-production",
    "access_token_ttl": 15,
    "refresh_token_ttl": 10080,
    "issuer": "goscratch",
    "audience": "goscratch-api"
  },
  "cors": {
    "allow_origins": "*",
    "allow_methods": "GET,POST,PUT,PATCH,DELETE,OPTIONS",
    "allow_headers": "Origin,Content-Type,Accept,Authorization,X-Request-ID",
    "allow_credentials": false
  },
  "redis": {
    "enabled": false,
    "host": "localhost",
    "port": 6379,
    "password": "",
    "db": 0
  },
  "rabbitmq": {
    "enabled": false,
    "url": "amqp://guest:guest@localhost:5672/",
    "prefetch_count": 10
  },
  "storage": {
    "mode": "local",
    "local": {
      "base_path": "./uploads"
    },
    "s3": {
      "endpoint": "",
      "bucket": "",
      "region": "",
      "access_key": "",
      "secret_key": ""
    }
  },
  "sse": {
    "enabled": false
  },
  "audit": {
    "enabled": false
  },
  "authorization": {
    "enabled": true
  },
  "worker": {
    "enabled": true,
    "concurrency": 2,
    "queue_name": "jobs",
    "exchange": ""
  },
  "email": {
    "enabled": false,
    "host": "smtp.example.com",
    "port": 587,
    "username": "",
    "password": "",
    "from": "noreply@example.com"
  },
  "rate_limit": {
    "enabled": true,
    "max": 100,
    "window_sec": 60
  },
  "observability": {
    "metrics": {
      "enabled": true,
      "port": 9090
    },
    "tracing": {
      "enabled": false,
      "endpoint": "http://localhost:4317"
    }
  }
}