package handler

import (
	"{{ .ModulePath }}/internal/module/{{ .Name }}/usecase"

	"github.com/gofiber/fiber/v2"
)

// Handler handles {{ .Name }} HTTP requests.
//
// TODO(scaffold): register routes on the fiber router in internal/platform/app/app.go:
//
//	h := {{ .Name }}handler.NewHandler(uc)
//	api.Get("/{{ .Name }}/:id", h.GetByID)
type Handler struct {
	useCase usecase.UseCase
}

// NewHandler creates a new {{ .Name }} handler.
func NewHandler(useCase usecase.UseCase) *Handler {
	return &Handler{useCase: useCase}
}

// GetByID retrieves a {{ .Name }} record by ID.
//
// TODO(scaffold): implement full handler logic — validation, error mapping, pagination.
func (h *Handler) GetByID(c *fiber.Ctx) error {
	id := c.Params("id")
	result, err := h.useCase.GetByID(c.UserContext(), id)
	if err != nil {
		return c.Status(fiber.StatusInternalServerError).JSON(fiber.Map{
			"success": false,
			"error":   fiber.Map{"message": err.Error()},
		})
	}
	return c.JSON(fiber.Map{"success": true, "data": result})
}
